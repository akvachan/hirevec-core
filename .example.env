PROTOCOL=http
HOST=localhost
PORT=8080

# Timeout on reading/writing the request body (in milliseconds)
REQUEST_READ_TIMEOUT=2000
REQUEST_WRITE_TIMEOUT=2000

# Timeout on graceful shutdown (in milliseconds)
GRACE_PERIOD=5000

# Postgres credentials 
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hirevec
POSTGRES_USER=
POSTGRES_PASSWORD=

# Logging level
# Available values are `DEBUG`, `ERROR`, `INFO`, `WARN`
LOG_LEVEL=DEBUG

# Authentication
# Generate via `openssl rand -hex 32`
SYMMETRIC_KEY=
# Generate via `openssl genpkey -algorithm ed25519 2>/dev/null -out /tmp/k.pem && printf "$(openssl pkey -in /tmp/k.pem -outform DER 2>/dev/null | tail -c 32 | od -A n -t x1 | tr -d ' \n')$(openssl pkey -in /tmp/k.pem -pubout -outform DER 2>/dev/null | tail -c 32 | od -A n -t x1 | tr -d ' \n')\n"`
ASYMMETRIC_KEY=
# See [Get your Google API client ID](https://developers.google.com/identity/oauth2/web/guides/get-google-api-clientid)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Development Access Token
# Generate via `go run cmd/token/main.go`
ACCESS_TOKEN=
