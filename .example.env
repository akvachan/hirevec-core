PROTOCOL=http
HOST=localhost
PORT=8080

# Timeout on reading/writing the request body (in milliseconds)
REQUEST_READ_TIMEOUT=2000
REQUEST_WRITE_TIMEOUT=2000

# Timeout on graceful shutdown (in milliseconds)
GRACE_PERIOD=5000

# Postgres credentials 
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hirevec
POSTGRES_USER=
POSTGRES_PASSWORD=

# Logging level
LOG_LEVEL=DEBUG

# Authentication
SYMMETRIC_KEY=
ASYMMETRIC_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
