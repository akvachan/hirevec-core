# Application protocol (http or https)
PROTOCOL=http

# Application host
HOST=localhost

# Application port
PORT=8080

# Timeout on reading the request body (in milliseconds)
REQUEST_READ_TIMEOUT=2000

# Timeout on writing the request body (in milliseconds)
REQUEST_WRITE_TIMEOUT=2000

# Timeout on graceful shutdown (in milliseconds)
GRACE_PERIOD=5000

# Postgres host
POSTGRES_HOST=localhost

# Postgres port
POSTGRES_PORT=5432

# Postgres database name
POSTGRES_DB=hirevec

# Postgres user
POSTGRES_USER=

# Postgres user password
POSTGRES_PASSWORD=

# Logging level
# Available values are `DEBUG`, `ERROR`, `INFO`, `WARN`
LOG_LEVEL=DEBUG

# Symmetric key
# Generate via `openssl rand -hex 32`
SYMMETRIC_KEY=

# Asymmetric key
# Generate via `openssl genpkey -algorithm ed25519 2>/dev/null -out /tmp/k.pem && printf "$(openssl pkey -in /tmp/k.pem -outform DER 2>/dev/null | tail -c 32 | od -A n -t x1 | tr -d ' \n')$(openssl pkey -in /tmp/k.pem -pubout -outform DER 2>/dev/null | tail -c 32 | od -A n -t x1 | tr -d ' \n')\n"`
ASYMMETRIC_KEY=

# Google client ID
# See [Get your Google API client ID](https://developers.google.com/identity/oauth2/web/guides/get-google-api-clientid)
GOOGLE_CLIENT_ID=

# Google client secret
GOOGLE_CLIENT_SECRET=

# Apple client ID
APPLE_CLIENT_ID=

# Apple client secret
APPLE_CLIENT_SECRET=

# Development Access Token
# Generate via `go run cmd/token/main.go`
ACCESS_TOKEN=
